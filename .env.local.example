# Anthropic API — REQUIRED
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API — REQUIRED (used only for embeddings in memory search)
OPENAI_API_KEY=sk-your-key-here

# Supabase — REQUIRED
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Access code for users without corporate email
ACCESS_CODE=your-access-code-here

# Gmail SMTP — REQUIRED for sending application emails
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password-here
