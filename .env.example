# ── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API – REQUIRED (chat)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API – REQUIRED (embeddings for memory search)
OPENAI_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase – REQUIRED
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Email ─────────────────────────────────────────────────────────────────────
# Resend API – REQUIRED for follow-up emails
RESEND_API_KEY=re_...

# Gmail SMTP – legacy / unused in current flow
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Cron ─────────────────────────────────────────────────────────────────────
# Cron job authentication
# Set this to any random string in Vercel project settings.
# Vercel passes it automatically as: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
